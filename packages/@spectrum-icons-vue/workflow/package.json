{
  "name": "@spectrum-icons-vue/workflow",
  "private": true,
  "version": "0.1.0",
  "description": "Vue-native Spectrum workflow icons",
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json",
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src",
    "scripts"
  ],
  "scripts": {
    "make-icons": "node ./scripts/generate-icons.cjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adobe/react-spectrum"
  },
  "dependencies": {
    "@adobe/spectrum-css-temp": "3.0.0-alpha.1",
    "@vue-spectrum/provider": "workspace:*",
    "@vue-spectrum/utils": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
