{
  "name": "@vue-spectrum/s2",
  "private": true,
  "version": "0.1.0",
  "description": "Spectrum 2 aggregation package for Vue Spectrum baseline ports",
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/adobe/react-spectrum"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@vue-spectrum/button": "workspace:*",
    "@vue-spectrum/checkbox": "workspace:*",
    "@vue-spectrum/dialog": "workspace:*",
    "@vue-spectrum/overlays": "workspace:*",
    "@vue-spectrum/provider": "workspace:*",
    "@vue-spectrum/radio": "workspace:*",
    "@vue-spectrum/switch": "workspace:*",
    "@vue-spectrum/table": "workspace:*",
    "@vue-spectrum/textfield": "workspace:*",
    "@vue-spectrum/tree": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
