{
  "name": "vue-spectrum-starter",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.2.2",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "echo \"Skipping publish for starter workspace\""
  },
  "dependencies": {
    "@vue-aria/virtualizer": "workspace:*",
    "@vue-spectrum/button": "workspace:*",
    "@vue-spectrum/checkbox": "workspace:*",
    "@vue-spectrum/combobox": "workspace:*",
    "@vue-spectrum/components": "workspace:*",
    "@vue-spectrum/dialog": "workspace:*",
    "@vue-spectrum/divider": "workspace:*",
    "@vue-spectrum/dnd": "workspace:*",
    "@vue-spectrum/form": "workspace:*",
    "@vue-spectrum/link": "workspace:*",
    "@vue-spectrum/listbox": "workspace:*",
    "@vue-spectrum/menu": "workspace:*",
    "@vue-spectrum/meter": "workspace:*",
    "@vue-spectrum/numberfield": "workspace:*",
    "@vue-spectrum/overlays": "workspace:*",
    "@vue-spectrum/progress": "workspace:*",
    "@vue-spectrum/provider": "workspace:*",
    "@vue-spectrum/radio": "workspace:*",
    "@vue-spectrum/searchfield": "workspace:*",
    "@vue-spectrum/slider": "workspace:*",
    "@vue-spectrum/statuslight": "workspace:*",
    "@vue-spectrum/switch": "workspace:*",
    "@vue-spectrum/table": "workspace:*",
    "@vue-spectrum/textfield": "workspace:*",
    "@vue-spectrum/tree": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "vite": "^5.4.19",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.2.0"
  }
}
